{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SecureStore",
  "version": "1.0.0",
  "identifier": "com.securestore.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SecureStore",
        "label": "main",
        "width": 1480,
        "height": 980,
        "minWidth": 1120,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["../public/favicon.svg", "icons/icon.ico"]
  }
}
